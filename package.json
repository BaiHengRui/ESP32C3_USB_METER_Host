{
  "name": "esp32c3_usb_meter_host",
  "version": "1.1.6beta",
  "description": "ESP32C3 USB METER Host Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.esp32c3.meter",
    "productName": "ESP32C3-METER",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "curve.html",
      "styles.css",
      "start.bat",
      "assets/**",
      "node_modules/**"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  },
  "keywords": [
    "electron",
    "esp32c3",
    "usb",
    "meter"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "chartjs-plugin-crosshair": "^2.0.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "esptool-js": "^0.6.0",
    "html2canvas": "^1.4.1",
    "serialport": "^12.0.0"
  }
}
